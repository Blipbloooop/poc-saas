generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTH (Better Auth — ne pas renommer)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  phone         String?
  role          UserRole  @default(MEMBER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  sessions      Session[]
  accounts      Account[]
  chantiers     Chantier[]
  interventions Intervention[]
  documents     Document[]

  members     Member[]
  invitations Invitation[]

  @@index([email])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─────────────────────────────────────────────
// MÉTIER — CHANTIERS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  MEMBER
  VIEWER
}

enum ChantierStatus {
  PROSPECT
  EN_COURS
  TERMINE
  ANNULE
}

enum DevisStatus {
  BROUILLON
  ENVOYE
  SIGNE
  REFUSE
  EXPIRE
}

enum FactureStatus {
  BROUILLON
  ENVOYEE
  PAYEE
  IMPAYEE
}

enum InterventionStatus {
  PLANIFIEE
  EN_COURS
  TERMINEE
  ANNULEE
}

enum DocumentCategorie {
  PLAN
  PHOTO
  BON_COMMANDE
  RAPPORT
  CONTRAT
  AUTRE
}

model Chantier {
  id          String         @id @default(cuid())
  reference   String
  nom         String
  description String?
  status      ChantierStatus @default(PROSPECT)
  adresse     String?
  ville       String?
  codePostal  String?
  budget      Float?
  dateDebut   DateTime?
  dateFin     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  responsableId String?
  responsable   User?   @relation(fields: [responsableId], references: [id])

  devis         Devis[]
  factures      Facture[]
  interventions Intervention[]
  documents     Document[]

  @@unique([organizationId, reference])
  @@index([status])
  @@index([responsableId])
  @@index([organizationId])
}

// ─── Prestations (catalogue de services pré-enregistrés) ─────────────────────

model Prestation {
  id          String   @id @default(cuid())
  label       String
  description String?
  prix        Float
  unite       String   @default("forfait")
  tva         Float    @default(20)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("prestations")
}

// ─── Devis ────────────────────────────────────────────────────────────────────

model Devis {
  id              String      @id @default(cuid())
  numero          String      @unique
  chantierId      String
  chantier        Chantier    @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  status          DevisStatus @default(BROUILLON)
  clientNom       String      @default("")
  clientEmail     String?
  clientAdresse   String?
  validiteJours   Int         @default(30)
  tvaDefault      Float       @default(20)
  mentionsLegales String?     @db.Text
  notes           String?     @db.Text
  totalHT         Float       @default(0)
  totalTVA        Float       @default(0)
  totalTTC        Float       @default(0)
  sentAt          DateTime?
  signedAt        DateTime?
  signatureToken  String?     @unique
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  lignes   LigneDevis[]
  factures Facture[]

  @@index([chantierId])
  @@map("devis")
}

model LigneDevis {
  id           String  @id @default(cuid())
  devisId      String
  devis        Devis   @relation(fields: [devisId], references: [id], onDelete: Cascade)
  ordre        Int     @default(0)
  label        String
  description  String?
  quantite     Float   @default(1)
  unite        String  @default("forfait")
  prixUnitaire Float   @default(0)
  tva          Float   @default(20)
  totalHT      Float   @default(0)

  @@index([devisId])
  @@map("lignes_devis")
}

// ─── Factures ─────────────────────────────────────────────────────────────────

model Facture {
  id            String        @id @default(cuid())
  numero        String        @unique
  chantierId    String
  chantier      Chantier      @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  devisId       String?
  devis         Devis?        @relation(fields: [devisId], references: [id])
  status        FactureStatus @default(BROUILLON)
  clientNom     String        @default("")
  clientEmail   String?
  clientAdresse String?
  totalHT       Float         @default(0)
  totalTVA      Float         @default(0)
  totalTTC      Float         @default(0)
  echeanceDate  DateTime?
  sentAt        DateTime?
  paidAt        DateTime?
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lignes LigneFacture[]

  @@index([chantierId])
  @@map("factures")
}

model LigneFacture {
  id           String  @id @default(cuid())
  factureId    String
  facture      Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)
  ordre        Int     @default(0)
  label        String
  description  String?
  quantite     Float   @default(1)
  unite        String  @default("forfait")
  prixUnitaire Float   @default(0)
  tva          Float   @default(20)
  totalHT      Float   @default(0)

  @@index([factureId])
  @@map("lignes_facture")
}

// ─── Interventions ────────────────────────────────────────────────────────────

model Intervention {
  id          String             @id @default(cuid())
  chantierId  String
  chantier    Chantier           @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  titre       String
  description String?            @db.Text
  status      InterventionStatus @default(PLANIFIEE)
  dateDebut   DateTime?
  dateFin     DateTime?
  memo        String?            @db.Text
  userId      String?
  user        User?              @relation(fields: [userId], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  documents Document[]

  @@index([chantierId])
  @@map("interventions")
}

// ─── Documents ────────────────────────────────────────────────────────────────

model Document {
  id             String            @id @default(cuid())
  nom            String
  categorie      DocumentCategorie @default(AUTRE)
  url            String
  taille         Int?
  mimeType       String?
  memo           String?
  chantierId     String?
  chantier       Chantier?         @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  interventionId String?
  intervention   Intervention?     @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  uploadedById   String
  uploadedBy     User              @relation(fields: [uploadedById], references: [id])
  createdAt      DateTime          @default(now())

  @@index([chantierId])
  @@index([interventionId])
  @@map("documents")
}

model Organization {
  id             String          @id
  name           String
  slug           String
  logo           String?
  createdAt      DateTime
  metadata       String?
  members        Member[]
  invitations    Invitation[]
  companyProfile CompanyProfile?
  chantiers      Chantier[]
  prestations    Prestation[]

  @@unique([slug])
  @@map("organization")
}

enum ActiviteBTP {
  PLOMBERIE
  ELECTRICITE
  MENUISERIE
  MACONNERIE
  PEINTURE
  CHAUFFAGE_CLIMATISATION
  COUVERTURE
  MULTI_SERVICES
  AUTRE
}

enum Effectif {
  SOLO
  DE_2_A_5
  DE_6_A_10
  DE_11_A_20
  PLUS_DE_20
}

// Infos légales et personnalisation de l'entreprise (complète Organization,
// que Better Auth ne prévoit pas d'étendre avec des champs métier custom)
model CompanyProfile {
  id                    String       @id @default(cuid())
  organizationId        String       @unique
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activite              ActiviteBTP  @default(AUTRE)
  activitePrecision     String?
  effectif              Effectif?
  siren                 String?
  siret                 String?
  adresse               String?
  codePostal            String?
  ville                 String?
  tvaIntracommunautaire String?
  mentionsLegales       String?      @db.Text
  brandColor            String?
  themeSecondaryColor   String?
  onboardingCompletedAt DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@map("company_profile")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  // Pré-renseigné par l'admin qui invite ; repris sur le compte une fois
  // l'invitation acceptée (le collaborateur ne saisit qu'un mot de passe).
  prenom    String?
  nom       String?
  telephone String?

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

// Étape 3 du wizard d'inscription (entreprise + infos légales) mise de côté
// le temps que l'utilisateur confirme son email — l'organisation et le
// CompanyProfile ne sont créés qu'une fois l'email vérifié (cf. finishPendingSignup).
model PendingSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  data      Json
  createdAt DateTime @default(now())

  @@map("pending_signup")
}
